---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { products, getProductBySlug, formatPrice, type Product } from '../../data/products';

export function getStaticPaths() {
  return products.map(product => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

interface Props {
  product: Product;
}

const { product } = Astro.props;
const isLowStock = product.stock > 0 && product.stock <= 2;
const isOutOfStock = product.stock === 0;

// Get related products (same category, excluding current)
const relatedProducts = products
  .filter(p => p.category === product.category && p.id !== product.id)
  .slice(0, 4);
---

<BaseLayout title={product.name} description={product.description || `Compra ${product.name} en Go Capi Go — tu tienda K-Pop en México.`}>
  <Navbar />

  <section class="product-detail">
    <div class="container">
      <!-- Breadcrumb -->
      <nav class="breadcrumb">
        <a href="/">Inicio</a>
        <span class="breadcrumb-sep">/</span>
        <a href="/productos">Catálogo</a>
        <span class="breadcrumb-sep">/</span>
        <span>{product.name}</span>
      </nav>

      <div class="product-layout">
        <!-- Product Image -->
        <div class="product-image-area">
          <div class="product-image-main">
            <div class="product-image-placeholder">
              <span class="product-image-emoji">
                {product.category === 'lightsticks' ? '🔦' :
                 product.category === 'sleeves' ? '🃏' :
                 product.category === 'papeleria' ? '✏️' :
                 product.category === 'merchandise' ? '🛍️' : '🎀'}
              </span>
            </div>
            {product.isNew && <span class="badge badge-new" style="position: absolute; top: 1rem; left: 1rem;">Nuevo</span>}
          </div>
        </div>

        <!-- Product Info -->
        <div class="product-info-area">
          <span class="product-artist">{product.artist}</span>
          <h1 class="product-title">{product.name}</h1>

          <div class="product-price-block">
            <span class="product-price">{formatPrice(product.price)}</span>
            <span class="product-tax-note">IVA incluido</span>
          </div>

          {product.description && (
            <div class="product-description">
              <p>{product.description}</p>
            </div>
          )}

          <div class="product-stock">
            {isOutOfStock ? (
              <span class="stock-badge stock-out">Agotado</span>
            ) : isLowStock ? (
              <span class="stock-badge stock-low">
                ⚡ ¡Últimas {product.stock} {product.stock === 1 ? 'pieza' : 'piezas'}!
              </span>
            ) : (
              <span class="stock-badge stock-ok">✓ En stock ({product.stock} disponibles)</span>
            )}
          </div>

          <div class="product-actions">
            {!isOutOfStock ? (
              <button class="btn btn-primary btn-lg product-add-btn" id="add-to-cart-btn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                  <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                </svg>
                Agregar al carrito
              </button>
            ) : (
              <button class="btn btn-secondary btn-lg" disabled>No disponible</button>
            )}
          </div>

          <div class="product-details-list">
            <div class="detail-item">
              <span class="detail-label">Categoría</span>
              <a href={`/productos?category=${product.category}`} class="detail-value">{product.category}</a>
            </div>
            <div class="detail-item">
              <span class="detail-label">Artista</span>
              <span class="detail-value">{product.artist}</span>
            </div>
            <div class="detail-item">
              <span class="detail-label">SKU</span>
              <span class="detail-value">{product.id.toUpperCase()}</span>
            </div>
          </div>

          <!-- Trust badges -->
          <div class="trust-badges">
            <div class="trust-item">
              <span>🛡️</span> <span>100% Original</span>
            </div>
            <div class="trust-item">
              <span>📦</span> <span>Envío seguro</span>
            </div>
            <div class="trust-item">
              <span>🇰🇷</span> <span>Importado de Corea</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Related Products -->
      {relatedProducts.length > 0 && (
        <section class="related-section">
          <h2>También te puede gustar</h2>
          <div class="related-grid">
            {relatedProducts.map(rp => (
              <a href={`/productos/${rp.slug}`} class="product-card">
                <div class="product-card__image">
                  <div class="product-card__placeholder">
                    <span class="product-card__emoji">
                      {rp.category === 'lightsticks' ? '🔦' :
                       rp.category === 'sleeves' ? '🃏' :
                       rp.category === 'papeleria' ? '✏️' :
                       rp.category === 'merchandise' ? '🛍️' : '🎀'}
                    </span>
                  </div>
                </div>
                <div class="product-card__info">
                  <span class="product-card__artist">{rp.artist}</span>
                  <h3 class="product-card__name">{rp.name}</h3>
                  <div class="product-card__footer">
                    <span class="product-card__price">{formatPrice(rp.price)}</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .product-detail {
    padding: var(--space-xl) 0 var(--space-3xl);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--color-text-dim);
    margin-bottom: var(--space-xl);
  }

  .breadcrumb a {
    color: var(--color-text-muted);
  }

  .breadcrumb-sep {
    opacity: 0.4;
  }

  .product-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    align-items: start;
  }

  .product-image-main {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .product-image-placeholder {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--gradient-card);
  }

  .product-image-emoji {
    font-size: 6rem;
    opacity: 0.5;
  }

  .product-artist {
    display: block;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-xs);
  }

  .product-title {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-lg);
  }

  .product-price-block {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
  }

  .product-price {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 800;
    color: var(--color-gold);
  }

  .product-tax-note {
    font-size: var(--text-xs);
    color: var(--color-text-dim);
  }

  .product-description {
    margin-bottom: var(--space-lg);
  }

  .product-description p {
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .product-stock {
    margin-bottom: var(--space-lg);
  }

  .stock-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 0.8rem;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: 600;
  }

  .stock-ok {
    background: rgba(76, 175, 80, 0.1);
    color: #66bb6a;
    border: 1px solid rgba(76, 175, 80, 0.2);
  }

  .stock-low {
    background: rgba(230, 199, 156, 0.15);
    color: var(--color-gold);
    border: 1px solid rgba(230, 199, 156, 0.25);
  }

  .stock-out {
    background: rgba(100, 100, 100, 0.15);
    color: var(--color-text-muted);
    border: 1px solid rgba(100, 100, 100, 0.2);
  }

  .product-actions {
    margin-bottom: var(--space-xl);
  }

  .product-add-btn {
    width: 100%;
  }

  .product-details-list {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-lg);
    margin-bottom: var(--space-lg);
  }

  .detail-item {
    display: flex;
    justify-content: space-between;
    padding: var(--space-sm) 0;
    font-size: var(--text-sm);
    border-bottom: 1px solid rgba(152, 68, 173, 0.08);
  }

  .detail-label {
    color: var(--color-text-dim);
  }

  .detail-value {
    color: var(--color-text-muted);
    text-transform: capitalize;
  }

  .trust-badges {
    display: flex;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .related-section {
    margin-top: var(--space-3xl);
    padding-top: var(--space-2xl);
    border-top: 1px solid var(--color-border);
  }

  .related-section h2 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-xl);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
  }

  @media (max-width: 768px) {
    .product-layout {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    .related-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .related-grid {
      grid-template-columns: 1fr;
    }

    .trust-badges {
      flex-direction: column;
    }
  }
</style>

<script define:vars={{ product }}>
  const btn = document.getElementById('add-to-cart-btn');
  if (btn) {
    btn.addEventListener('click', () => {
      const CART_KEY = 'gocapigo-cart';
      let items = [];
      try {
        const stored = localStorage.getItem(CART_KEY);
        items = stored ? JSON.parse(stored) : [];
      } catch {}

      const existing = items.find(i => i.product.id === product.id);
      if (existing) {
        existing.quantity = Math.min(existing.quantity + 1, product.stock);
      } else {
        items.push({ product, quantity: 1 });
      }

      localStorage.setItem(CART_KEY, JSON.stringify(items));
      const count = items.reduce((s, i) => s + i.quantity, 0);
      window.dispatchEvent(new CustomEvent('cart-updated', { detail: { count } }));

      // Visual feedback
      btn.innerHTML = `
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
        ¡Agregado!
      `;
      btn.classList.remove('btn-primary');
      btn.classList.add('btn-gold');
      setTimeout(() => {
        const qty = items.find(i => i.product.id === product.id)?.quantity || 0;
        btn.innerHTML = `
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
          </svg>
          Agregar al carrito (${qty} en carrito)
        `;
        btn.classList.add('btn-primary');
        btn.classList.remove('btn-gold');
      }, 1500);
    });
  }
</script>
